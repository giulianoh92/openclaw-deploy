{
  "gateway": {
    "port": 18789
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "pairing",
      "groups": {
        "*": {
          "requireMention": true
        }
      }
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/vault",
      "model": "anthropic/claude-sonnet-4-6",
      "contextTokens": 80000,
      "compaction": {
        "mode": "safeguard",
        "model": "anthropic/claude-haiku-4-5",
        "reserveTokensFloor": 20000
      },
      "heartbeat": {
        "every": "30m",
        "target": "last",
        "activeHours": {
          "start": "08:00",
          "end": "23:00",
          "timezone": "America/Argentina/Buenos_Aires"
        }
      }
    }
  }
}
