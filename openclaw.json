{
  "gateway": {
    "port": 18789
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "pairing",
      "groups": {
        "*": {
          "requireMention": true
        }
      }
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/vault",
      "model": "anthropic/claude-sonnet-4-6"
    }
  }
}
